<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
            <stroke android:width="2dp" android:color="#00FF00" /> <corners android:radius="12dp" />
            <padding android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" /> <stroke android:width="2dp" android:color="#333333" /> <corners android:radius="12dp" />
            <gradient
                android:angle="270"
                android:startColor="#2A2A2A"
                android:endColor="#121212" />
        </shape>
    </item>
</selector>